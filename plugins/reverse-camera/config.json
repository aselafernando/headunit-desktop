{
    "name":   "reverse-camera",
    "label":  "Reverse Camera",
    "source": "qrc:/plugins/reverse-camera/reverse-camera.qml",
    "icon":   "qrc:/qml/icons/android-camera.png",
    "config":{
        "type": "items",
        "items":[
            {
                "label": "Camera type",
                "name":  "camera",
                "type":  "combobox",
                "defaultValue":"custom",
                "values": {"custom":"Custom"}
            },
            {
                "label":"GStreamer pipeline",
                "name": "gs_pipeline",
                "type": "textfield",
                "conditional":true,
                "conditionTarget": "camera",
                "conditionValue":  "custom",
                "defaultValue": "videotestsrc ! capsfilter caps=\"video/x-raw,format=YV12\""
            }
        ]
    }
}
